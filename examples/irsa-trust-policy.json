{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Principal": {
                "Federated": "arn:aws:iam::123456789012:oidc-provider/<cluster-oidc-issuer>"
            },
            "Action": "sts:AssumeRoleWithWebIdentity",
            "Condition": {
                "StringLike": {
                    "<cluster-oidc-issuer>:sub": "system:serviceaccount:*:*"
                }
            }
        }
    ]
}
